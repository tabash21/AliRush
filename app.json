{
  "expo": {
    "name": "AliRush",
    "slug": "AliRush",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/aliRush-squre.png",
    "scheme": "alirush",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/aliRush-squre.png",
        "backgroundImage": "./assets/images/aliRush-squre.png",
        "monochromeImage": "./assets/images/aliRush-squre.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tal_ben_shushan.aliRush"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/aliRush-squre.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/aliRush-squre.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e01e4277-7e83-4a95-8cc1-3bf1901f935b"
      }
    }
  }
}
