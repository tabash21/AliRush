{
  "expo": {
    "name": "Word Rush",
    "slug": "WordRush",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./src/assets/images/wordRush-icon.png",
    "scheme": "wordrush",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/wordRush-squre.png",
        "backgroundImage": "./src/assets/images/wordRush-squre.png",
        "monochromeImage": "./src/assets/images/wordRush-squre.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tabash21.wordrush",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/wordRush-squre.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/wordRush-squre.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9927dee9-d3ee-447a-bcef-6af7894da606"
      }
    }
  }
}
